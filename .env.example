# API Interesting Facts - Environment Variables
# Copiar este archivo a .env y completar los valores

version=0.0.1
PORT=3009
NODE_ENV=development
PINO_LOG_LEVEL=debug
TOKEN=tu-token-aqui
DOTENV_TIPS=false

# Firebase Service Account
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----"
