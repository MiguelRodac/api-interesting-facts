# =============================================
# API Interesting Facts - .gitignore
# =============================================

# Compiled output
/build/
dist/
out/

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# Package managers lock files (use only ONE)
# Comment/uncomment the one you use
# npm
# package-lock.json
# yarn
# yarn.lock
# pnpm
pnpm-lock.yaml

# Environment variables (NEVER commit these)
.env

# Logs
logs/
*.log

# IDEs and editors
.idea/
.vscode/
.settings/
*.sublime-workspace
*.sublime-settings
.c9/
*.launch
.history/

# OS files
.DS_Store
Thumbs.db

# OpenCode / Agent configs
.atl/
specs/

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.tmp/

# Build artifacts
*.tgz
