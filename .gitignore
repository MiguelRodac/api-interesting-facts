# =============================================
# API Interesting Facts - .gitignore
# =============================================

# Compiled output
/build/
dist/
out/

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# Package managers lock files (use only ONE)
# Comment/uncomment the one you use
# npm
# package-lock.json
# yarn
# yarn.lock
# pnpm
pnpm-lock.yaml

# Environment variables (NEVER commit these)
.env

# Logs
logs/
*.log

# IDEs and editors
.vscode/

# OpenCode / Agent configs
.atl/
specs/
openspec/

# Postman local overrides
docs/postman/*.local.json